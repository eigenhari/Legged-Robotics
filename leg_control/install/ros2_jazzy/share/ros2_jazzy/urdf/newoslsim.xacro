<?xml version="1.0"?>
<robot name="oslsim" xmlns:xacro="http://www.ros.org/wiki/xacro">
    <xacro:property name="mesh_dir" value="package://ros2_jazzy"/>
    
  <link name="world"/>
  <link name="base_link">
    <inertial>
      <origin rpy="0.0 0 0" xyz="0 0 0"/>
      <mass value="0.00001" />
      <inertia ixx="1.0e-07" ixy="0.0" ixz="0.0" iyy="1.0e-07" iyz="0.0" izz="1.0e-07"/>
    </inertial>
  </link>
  
  <joint name="base_link_joint" type="fixed">
    <parent link="world" />
      <child link="base_link" />
  </joint>

  <link name="slider">
    <!-- <visual>
    </visual> -->
    <inertial>
        <origin rpy="0.0 0 0" xyz="0 0 0"/>
        <mass value="0.001" />
        <inertia ixx="1.0e-07" ixy="0.0" ixz="0.0" iyy="1.0e-07" iyz="0.0" izz="1.0e-07"/>
    </inertial>
    <collision>
        <origin rpy="0.0 0 0" xyz="0 0 0"/>
        <geometry>
            <box size="0.25 0.25 0.01"/>
        </geometry>
    </collision>
  </link>

  <gazebo reference="slider">
      <kp>1000.0</kp>
      <kd>1000.0</kd>
      <mu1>0.5</mu1>
      <mu2>0.5</mu2>
      <material>Gazebo/Red</material>
  </gazebo>

  <joint name="slider_joint" type="prismatic">
      <origin xyz="0 0 0" rpy="0.0 0.0 0.0"/>
      <parent link="base_link" />
      <child link="slider" />
      <axis xyz="1 0 0" />
      <limit effort="1" lower="-10.0" upper="100.0" velocity="1" />
      <dynamics damping="0.05" friction="0.1"/>
  </joint>

  <link name="entity">
      <inertial>
            <origin rpy="0.0 0 0" xyz="0 0 0"/>
            <mass value="0.1" />
            <inertia ixx="4.16666666667e-05" ixy="0.0" ixz="0.0" iyy="4.16666666667e-05" iyz="0.0" izz="4.16666666667e-05"/>
        </inertial>
  </link>

  <gazebo reference="entity">
      <kp>1000.0</kp>
      <kd>1000.0</kd>
      <mu1>0.5</mu1>
      <mu2>0.5</mu2>
      <material>Gazebo/Blue</material>
  </gazebo>

  <joint name="entity_joint" type="fixed">
      <parent link="slider"/>
      <child link="entity"/>
      <origin xyz="0 0 -0.05" rpy="0 0 0"/>
  </joint>


  <link name="body">
    <inertial>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <mass
        value="0.1" />
      <inertia
        ixx="0.001"
        ixy="0"
        ixz="0"
        iyy="0.001"
        iyz="0"
        izz="0.001" />
    </inertial>
  </link>

  <gazebo reference="body">
      <kp>1000.0</kp>
      <kd>1000.0</kd>
      <mu1>0.5</mu1>
      <mu2>0.5</mu2>
  </gazebo>

  <joint name="root_joint" type="fixed">
    <parent link="entity"/>
    <child link="body"/>
  </joint>  

  <link name="thigh">
    <inertial>
      <origin
        xyz="0.0079 0.105 -0.18514"
        rpy="1.5708 0 0" />
      <mass
        value="0.55797" />
      <inertia
        ixx="0.0451"
        ixy="-0.0023863"
        ixz="0.00041503"
        iyy="0.017843"
        iyz="-0.00079008"
        izz="0.046937" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 -0.004"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="$(arg mesh_dir)/meshes/thigh.dae" />
      </geometry>
      <material name="">
        <pbr>
          <albedo>0.79216 0.81961 0.93333 1</albedo>
          <metalness>0.0</metalness>
          <roughness>0.4</roughness>
        </pbr>
      </material>
    </visual>
    <collision>
      <origin
        xyz="0.0079 0.105 -0.18514"
        rpy="1.5708 0 0" />
      <geometry>
        <box size="0.15 0.3 0.15"/>
      </geometry>
    </collision>
  </link>

  <gazebo reference="thigh">
      <kp>1000.0</kp>
      <kd>1000.0</kd>
      <mu1>0.5</mu1>
      <mu2>0.5</mu2>
  </gazebo>

  <joint name="hip" type="revolute">
    <parent link="body"/>
    <child link="thigh"/>
    <origin xyz="-0.03 -0.015 0" rpy="0 0 0" />
    <axis xyz="-0.03 1 0" />
    <dynamics damping="0.5" friction="0.5"/>
    <limit effort="10.0" velocity="100" lower="-1.57" upper="1.57" />
  </joint>


    <link name="socket">
    <inertial>
      <origin
        xyz="0.0149 -0.105 -0.18907"
        rpy="1.5708 0 0" />
      <mass
        value="0.55993" />
      <inertia
        ixx="0.045555"
        ixy="-0.0028683"
        ixz="-0.00027507"
        iyy="0.018107"
        iyz="0.0020012"
        izz="0.04735" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="$(arg mesh_dir)/meshes/socket.dae" />
      </geometry>
      <material name="">
        <pbr>
          <albedo>0.79216 0.81961 0.93333 1</albedo>
          <metalness>0.0</metalness>
          <roughness>0.4</roughness>
        </pbr>
      </material>
    </visual>
    <collision>
      <origin
        xyz="0.0149 -0.105 -0.18907"
        rpy="1.5708 0 0" />
      <geometry>
        <box size="0.15 0.3 0.15"/>
      </geometry>
    </collision>
  </link>

  <gazebo reference="socket">
      <kp>1000.0</kp>
      <kd>1000.0</kd>
      <mu1>0.5</mu1>
      <mu2>0.5</mu2>   
  </gazebo>

  <joint name="osl_hip" type="revolute">
    <parent link="body"/>
    <child link="socket"/>
    <origin xyz="0 0.015 0" rpy="0 0 0" />
    <axis xyz="0 1 0" />
    <dynamics damping="0.5" friction="0.5"/>
    <limit effort="10.0" velocity="100" lower="-1.57" upper="1.57" />
  </joint>

  <link name="shin">
    <inertial>
      <origin
        xyz="0.00071104 -0.14671 -0.059447"
        rpy="0 0 0" />
      <mass
        value="0.1" />
      <inertia
        ixx="0.00092445"
        ixy="-1.5017E-05"
        ixz="-2.9597E-06"
        iyy="0.00064852"
        iyz="1.2705E-05"
        izz="0.0013496" />
    </inertial>
    <visual>
      <origin
        xyz="0.006 0.01 0.006"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="$(arg mesh_dir)/meshes/shin.dae" />
      </geometry>
      <material name="">
        <pbr>
          <albedo>0.79216 0.81961 0.93333 1</albedo>
          <metalness>0.0</metalness>
          <roughness>0.4</roughness>
        </pbr>
      </material>
    </visual>
    <collision>
      <origin
        xyz="0.00071104 -0.14671 -0.059447"
        rpy="0 0 0" />
      <geometry>
        <box size="0.1 0.35 0.1"/>
      </geometry>
    </collision>
  </link>

  <gazebo reference="shin">
      <kp>1000.0</kp>
      <kd>1000.0</kd>
      <mu1>0.5</mu1>
      <mu2>0.5</mu2>  
  </gazebo>

  <joint name="knee"
    type="revolute">
    <origin
      xyz="-0.0073766 0.057865 -0.4427"
      rpy="1.5708 0 0" />
    <parent
      link="thigh" />
    <child
      link="shin" />
    <axis
      xyz="0 0 1" />
    <dynamics damping="0.5" friction="0.5"/>
    <limit effort="10.0" velocity="100" lower="-1.57" upper="1.57" />      
  </joint>

  <link name="osl_shank">
    <inertial>
      <origin
        xyz="0.00071137 -0.14671 0.059447"
        rpy="0 0 0" />
      <mass
        value="0.1" />
      <inertia
        ixx="0.00092446"
        ixy="-1.5017E-05"
        ixz="2.9586E-06"
        iyy="0.00064852"
        iyz="-1.2701E-05"
        izz="0.0013496" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="$(arg mesh_dir)/meshes/osl_shank.dae" />
      </geometry>
      <material name="">
        <pbr>
          <albedo>0.79216 0.81961 0.93333 1</albedo>
          <metalness>0.0</metalness>
          <roughness>0.4</roughness>
        </pbr>
      </material>
    </visual>
    <collision>
      <origin
        xyz="0.00071137 -0.14671 0.059447"
        rpy="0 0 0" />
      <geometry>
        <box size="0.1 0.35 0.1"/>
      </geometry>
    </collision>
  </link>

  <gazebo reference="osl_shank">
    <kp>1000.0</kp>
    <kd>1000.0</kd>
    <mu1>0.5</mu1>
    <mu2>0.5</mu2>
    <!-- Native gz-sim IMU sensor -->
    <sensor name="osl_foot_imu" type="imu">
      <always_on>true</always_on>
      <update_rate>50</update_rate>
      <visualize>true</visualize>
      


      <topic>imu/osl_shank</topic>


      <pose>0 0 0 0 0 0</pose>
    </sensor>

    </gazebo>



<joint name="osl_knee"
    type="revolute">
    <origin
      xyz="-0.0073766 -0.062441 -0.4427"
      rpy="1.5708 0 0" />
    <parent
      link="socket" />
    <child
      link="osl_shank" />
    <axis
      xyz="0 0 1" />
    <dynamics damping="0.5" friction="0.5"/>
    <limit effort="10.0" velocity="100" lower="-1.57" upper="1.57" />      
  </joint>



  <link name="foot">
    <inertial>
      <origin
        xyz="0.029606 -0.056108 0.013102"
        rpy="-0.175 0 0" />
      <mass
        value="0.01" />
      <inertia
        ixx="0.00051563"
        ixy="2.5317E-06"
        ixz="-1.6036E-06"
        iyy="0.00049449"
        iyz="0.0001344"
        izz="0.0001125" />
    </inertial>
    <visual>
      <origin
        xyz="-0.0035 0.02 0.024"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="$(arg mesh_dir)/meshes/foot.dae" />
      </geometry>
      <material name="">
        <pbr>
          <albedo>0.79216 0.81961 0.93333 1</albedo>
          <metalness>0.0</metalness>
          <roughness>0.4</roughness>
        </pbr>
      </material>
      <!-- <material
        name="">
        <color
          rgba="0.79216 0.81961 0.93333 1" />
      </material> -->
    </visual>
    <collision>
      <origin
        xyz="0.029606 -0.065 0.05"
        rpy="0 0 0" />
      <geometry>
        <box size="0.0675 0.025 0.2"/>
      </geometry>
      <surface>
        <friction>
          <ode>
            <mu>1.0</mu>
            <mu2>1.0</mu2>
            <fdir1>1 0 0</fdir1>
            <slip1>0</slip1>
            <slip2>0</slip2>
          </ode>
          <torsional>
            <coefficient>0.0</coefficient>
            <patch_radius>0</patch_radius>
            <surface_radius>0</surface_radius>
            <use_patch_radius>1</use_patch_radius>
            <ode>
              <slip>0</slip>
            </ode>
          </torsional>
        </friction>  
      </surface>
    </collision>
  </link>

  <gazebo reference="foot">
      <kp>1000.0</kp>
      <kd>1000.0</kd>
      <mu1>1.0</mu1>
      <mu2>1.0</mu2>    
  </gazebo>

  <joint name="ankle"
    type="revolute">
    <origin
      xyz="-0.00077967 -0.3134 -0.026811"
      rpy="0 1.5708 0" />
    <parent
      link="shin" />
    <child
      link="foot" />
    <axis
      xyz="1 0 0" />
    <dynamics damping="0.5" friction="0.5"/>      
    <limit effort="10.0" velocity="100" lower="-1.57" upper="1.57" />      
  </joint>

  <link name="osl_foot">
    <inertial>
      <origin
        xyz="0.029606 -0.056108 0.033102"
        rpy="0.175 -1.5708 0" />
      <mass
        value="0.01" />
      <inertia
        ixx="0.00051564"
        ixy="-2.531E-06"
        ixz="-1.6019E-06"
        iyy="0.0004945"
        iyz="-0.0001344"
        izz="0.0001125" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0.175 -1.5708 -3.1416" />
      <geometry>
        <mesh
          filename="$(arg mesh_dir)/meshes/osl_foot.dae" />
      </geometry>
      <material name="">
        <pbr>
          <albedo>0.79216 0.81961 0.93333 1</albedo>
          <metalness>0.0</metalness>
          <roughness>0.4</roughness>
        </pbr>
      </material>
      <!-- <material
        name="">
        <color
          rgba="0.79216 0.81961 0.93333 1" />
      </material> -->
    </visual>
    <collision>
      <origin
        xyz="0.03 -0.065 0.03"
        rpy="0 -1.5708 0" />
      <geometry>
        <box size="0.0675 0.025 0.2"/>
      </geometry>
      <surface>
        <friction>
          <ode>
            <mu>1.0</mu>
            <mu2>1.0</mu2>
            <fdir1>1 0 0</fdir1>
            <slip1>0</slip1>
            <slip2>0</slip2>
          </ode>
          <torsional>
            <coefficient>0.0</coefficient>
            <patch_radius>0</patch_radius>
            <surface_radius>0</surface_radius>
            <use_patch_radius>1</use_patch_radius>
            <ode>
              <slip>0</slip>
            </ode>
          </torsional>
        </friction>    
      </surface>
    </collision>
  </link>

  <joint name="osl_ankle"
    type="revolute">
    <origin
      xyz="-0.00077967 -0.3134 0.026811"
      rpy="0 0 0" />
    <parent
      link="osl_shank" />
    <child
      link="osl_foot" />
    <axis
      xyz="0 0 1" />
    <dynamics damping="0.5" friction="0.5"/>      
    <limit effort="10.0" velocity="100" lower="-1.57" upper="1.57" />      
  </joint>


    <link name="foot_heel">
    <inertial>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <mass value="0.00001" />
          <inertia ixx="1.6e-08" ixy="0.0" ixz="0.0" iyy="1.6e-08" iyz="0.0" izz="1.6e-08"/>
      </inertial>
      <collision>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry>
              <sphere radius="0.020"/>
          </geometry>
  
      </collision>
  </link>

  <gazebo reference="foot_heel">
      <kp>1000.0</kp>
      <kd>1000.0</kd>
      <mu1>0.5</mu1>
      <mu2>0.5</mu2>
  </gazebo>

  <joint name="foot_heel_joint" type="fixed">
      <parent link="foot"/>
      <child link="foot_heel"/>
      <origin xyz="0.03 -0.065 0" rpy="0 0 0"/>
  </joint>

  <link name="osl_foot_loadcell_link">
    <inertial>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <mass value="0.00001" />
          <inertia ixx="1.6e-08" ixy="0.0" ixz="0.0" iyy="1.6e-08" iyz="0.0" izz="1.6e-08"/>
      </inertial>
      <collision name="osl_foot_loadcell_link_collision_1">
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry>
              <sphere radius="0.020"/>
          </geometry>
      </collision>
  </link>

  <gazebo reference="osl_foot_loadcell_link">
      <kp>1000.0</kp>
      <kd>1000.0</kd>
      <mu1>0.5</mu1>
      <mu2>0.5</mu2>
  </gazebo>

  <!-- <gazebo reference="osl_foot_loadcell_link">
    <kp>1000.0</kp>
    <kd>1000.0</kd>
    <mu1>0.5</mu1>
    <mu2>0.5</mu2>
    <preserveFixedJoint>true</preserveFixedJoint> 
  </gazebo> -->

  <!-- CHANGE THIS -->
  <joint name="osl_foot_loadcell_link_joint" type="revolute">
    <parent link="osl_foot"/>
    <child link="osl_foot_loadcell_link"/>
    <origin xyz="-0.03 -0.065 0.03" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit effort="0" lower="0" upper="0" velocity="0"/>  <!-- zero limits = acts fixed -->
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <gazebo reference="osl_foot_loadcell_link_joint">
    <sensor name="loadcell" type="force_torque">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <topic>/loadcell/osl_foot</topic> 
      <force_torque>
        <frame>child</frame>
        <measure_direction>child_to_parent</measure_direction>
      </force_torque>
    </sensor>
  </gazebo>

  <gazebo reference="osl_foot_loadcell_link">
    <sensor name='sensor_contact' type='contact'>
      <!-- <always_on>true</always_on> -->
      <!-- <update_rate>50</update_rate> -->
      <!-- <topic>contact/foot</topic> -->
      <contact>
          <collision>osl_foot_loadcell_link_collision_1_collision_1</collision>
      </contact>
    </sensor>
  </gazebo>

  <!-- <gazebo>
    <plugin filename="gz-sim-touchplugin-system"
            name="gz::sim::systems::TouchPlugin">
        <target>gplane</target>
        <namespace>wall</namespace>
        <time>0.001</time>
        <enabled>true</enabled>
    </plugin>
  </gazebo> -->



  <gazebo reference="osl_foot">
    <!-- Native gz-sim IMU sensor -->
    <sensor name="osl_foot_imu" type="imu">
      <always_on>true</always_on>
      <update_rate>50</update_rate>
      <!-- <visualize>true</visualize> -->

      <topic>imu/foot</topic>

      <!-- <pose>0 0 0 0 0 0</pose> -->
    </sensor>

    </gazebo>


    <ros2_control name="OSLSimSystem" type="system">
      <hardware>
        <plugin>gz_ros2_control/GazeboSimSystem</plugin>
      </hardware>

      <joint name="hip">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="osl_hip">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="knee">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="osl_knee">
        <command_interface name="effort"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>
      <joint name="ankle">
        <command_interface name="position"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="osl_ankle">
        <command_interface name="effort"/>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>
    </ros2_control>

  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find ros2_jazzy)/config/controllers.yaml</parameters>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin filename="gz-sim-imu-system"
          name="gz::sim::systems::Imu">
    </plugin>
  </gazebo>
  <gazebo>
    <plugin filename="gz-sim-forcetorque-system"
            name="gz::sim::systems::ForceTorque">
    </plugin>
  </gazebo>

  <gazebo>
    <plugin filename="gz-sim-touchplugin-system"
          name="gz::sim::systems::TouchPlugin">
      <target>ground_plane</target>
      <namespace>foot</namespace>
      <time>0.001</time>
      <enabled>true</enabled>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin filename="gz-sim-contact-system"
        name="gz::sim::systems::Contact">
    </plugin>
  </gazebo>

  <gazebo>
    <plugin
      filename="gz-sim-odometry-publisher-system"
      name="gz::sim::systems::OdometryPublisher">
      <odom_frame>world</odom_frame>
      <robot_base_frame>base_link</robot_base_frame>
      <odom_topic>oslsim/odom</odom_topic>
      <tf_topic>/model/oslsim/tf</tf_topic>
      <dimensions>3</dimensions>
      <xyz_offset>0 0 0</xyz_offset>
      <rpy_offset>0 0 0</rpy_offset>
      <gaussian_noise>0.01</gaussian_noise>
      <update_rate>50</update_rate>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
        <joint_name>slider_joint</joint_name>
        <joint_name>osl_foot_loadcell_link_joint</joint_name>
    </plugin>
  </gazebo>

</robot>