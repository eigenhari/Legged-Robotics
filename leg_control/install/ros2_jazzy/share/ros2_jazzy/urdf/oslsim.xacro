            <use_patch_radius>1</use_patch_radius>
            <ode>
              <slip>0</slip>
            </ode>
          </torsional>
        </friction>    
      </surface>
    </collision>
  </link>

  <joint name="osl_extension" type="fixed">
    <parent link="osl_shin"/>
    <child link="osl_shank"/>
    <origin
      xyz="0 -0.15 -0.04"
      rpy="0 0 0" />
  </joint> -->
  
  <link name="osl_foot">
     <inertial>
      <origin
        xyz="-0.006 -0.156 -0.025"
        rpy="-0.25 0 0" />
      <mass
        value="0.01" />
      <inertia
        ixx="0.00051563"
        ixy="-2.53E-06"
        ixz="-1.60E-06"
        iyy="0.00049449"
        iyz="-0.000134"
        izz="0.0001125" />
    </inertial>
    <visual>
      <origin
        xyz="-0.016 -0.101 -0.045"
        rpy="-0.25 0 0" />
      <geometry>
        <mesh
          filename="$(arg mesh_dir)/meshes/osl_foot.obj"
          scale="0.00091 0.00091 0.00091"/>
      </geometry>
    </visual>
    <collision>
      <origin
        xyz="-0.068 -0.28 0.07"
        rpy="-0.25 1.57 0" />
      <geometry>
        <box size="0.0675 0.025 0.2"/>
      </geometry>
      <material
        name="">
        <color
          rgba="0.0 0.80 0.0 1" />
      </material>
      <surface>
        <friction>
          <ode>
            <mu>1.0</mu>
            <mu2>1.0</mu2>
            <fdir1>1 0 0</fdir1>
            <slip1>0</slip1>
            <slip2>0</slip2>
          </ode>
          <torsional>
            <coefficient>0.0</coefficient>
            <patch_radius>0</patch_radius>
            <surface_radius>0</surface_radius>
            <use_patch_radius>1</use_patch_radius>
            <ode>
              <slip>0</slip>
            </ode>
          </torsional>
        </friction>    
      </surface>
    </collision>
  </link>

  <joint name="osl_ankle" type="revolute">
    <parent link="osl_shin"/>
    <child link="osl_foot"/>
    <origin
      xyz="-0.00077967 -0.3134 -0.026811"
      rpy="0.21 1.5708 0" />
    <axis xyz="1 0 0"/>
     <limit effort="1.0" velocity="100" lower="-1.57" upper="1.57" /> 
    <dynamics damping="0.5" friction="0.5"/>
  </joint>


  <!-- <link name="foot_heel">
    <inertial>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <mass value="0.00001" />
          <inertia ixx="1.6e-08" ixy="0.0" ixz="0.0" iyy="1.6e-08" iyz="0.0" izz="1.6e-08"/>
      </inertial>
      <collision>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry>
              <sphere radius="0.020"/>
          </geometry>
      </collision>
  </link> -->

  <!-- <link name="osl_foot_loadcell_link">
    <inertial>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <mass value="0.00001" />
          <inertia ixx="1.6e-08" ixy="0.0" ixz="0.0" iyy="1.6e-08" iyz="0.0" izz="1.6e-08"/>
      </inertial>
      <collision>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry>
              <sphere radius="0.020"/>
          </geometry>
      </collision>
  </link> -->

  <!-- <joint name="foot_heel_joint" type="fixed">
      <parent link="foot"/>
      <child link="foot_heel"/>
      <origin xyz="0.03 -0.065 0" rpy="0 0 0"/>
  </joint> -->

  <!-- <joint name="osl_foot_loadcell_link_joint" type="fixed">
      <parent link="osl_foot"/>
      <child link="osl_foot_loadcell_link"/>
      <origin xyz="-0.03 -0.065 0.03" rpy="0 0 0"/>
  </joint> -->
  <!-- ========================= -->
  <!-- IMU SENSOR (ROS 2 OK)    -->
  <!-- ========================= -->

  <gazebo reference="osl_ankle_imu">
    <sensor name="ankle_imu" type="imu">
      <always_on>true</always_on>
      <update_rate>200</update_rate>
      <visualize>true</visualize>

      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0</mean><stddev>0.0003</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>0.0003</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>0.0003</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></z>
        </linear_acceleration>
      </imu>
    </sensor>
  </gazebo>


  <gazebo reference="osl_shin_imu">
    <sensor name="shin_imu" type="imu">
      <always_on>true</always_on>
      <update_rate>200</update_rate>
      <visualize>true</visualize>

      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0</mean><stddev>0.0003</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>0.0003</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>0.0003</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></z>
        </linear_acceleration>
      </imu>
    </sensor>
  </gazebo>

  <!-- ========================= -->
  <!-- ROS 2 CONTROL INTERFACE  -->
  <!-- ========================= -->



  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    
    <joint name="slider_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="hip">
      <command_interface name="position" />
      <state_interface name="position" />
      <state_interface name="velocity"/>
    </joint>
    <joint name="osl_hip">
      <command_interface name="position" />
      <state_interface name="position" />
      <state_interface name="velocity"/>
    </joint>
    <joint name="knee">
      <command_interface name="position" />
      <state_interface name="position" />
      <state_interface name="velocity"/>
    </joint>
    <joint name="osl_knee">
      <command_interface name="position" />
      <state_interface name="position" />
      <state_interface name="velocity"/>
    </joint>
    <joint name="ankle">
      <command_interface name="position" />
      <state_interface name="position" />
      <state_interface name="velocity"/>
    </joint>
    <joint name="osl_ankle">
      <command_interface name="position" />
      <state_interface name="position" />
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>



  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find ros2_jazzy)/config/controllers.yaml</parameters>
    </plugin>
  </gazebo>



</robot>
